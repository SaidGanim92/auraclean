# ==========================================================================
# AURA CLEAN — משתני סביבה
# העתק קובץ זה ל-.env.local ומלא את הערכים. אל תעלה את .env.local ל-Git.
# ==========================================================================

# --- Supabase (מפרויקט Supabase → Project Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# מפתח service-role — צד שרת בלבד! לעולם לא ב-NEXT_PUBLIC ולא בקוד לקוח.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Admin ---
# האימייל היחיד שמורשה להיכנס ל-/admin (צור משתמש עם אימייל זה ב-Supabase Auth)
ADMIN_EMAIL=admin@your-domain.com
# מצב הדגמה ללא Supabase — רק בפיתוח מקומי (true/false)
ALLOW_DEMO_ADMIN=false

# --- תרגום אוטומטי HE→AR (אופציונלי; ללא מפתח הערבית תהיה טיוטה = העברית) ---
# TRANSLATE_PROVIDER=google   # google | deepl
TRANSLATE_PROVIDER=
TRANSLATE_API_KEY=
# --- Meta Pixel (נטען רק לאחר אישור עוגיות) ---
NEXT_PUBLIC_META_PIXEL_ID=

# --- כללי ---
NEXT_PUBLIC_WHATSAPP_NUMBER=972500000000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
